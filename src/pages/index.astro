---
import Layout from "../layouts/Layout.astro";

const phoneHref = "tel:+19545550197";
const appointmentHref = "#contact";

const navItems = [
	{ label: "Home", href: "#home" },
	{ label: "Services", href: "#services" },
	{ label: "About", href: "#about" },
	{ label: "Reviews", href: "#reviews" },
	{ label: "Contact", href: "#contact" },
];

const images = {
	logo: "/images/logo.png",
	hero: "/images/busy outside lot.png",
	about: "/images/empty lot.png",
	generalRepair: "/images/general repair.png",
	tire: "/images/replacing a tire.png",
	maintenance: "/images/maintenance.png",
	brake: "/images/brake repair.png",
	electrical: "/images/electrical.png",
	engine: "/images/engine.png",
	transmission: "/images/transmission.png",
	ac: "/images/ac repair.png",
	towing: "/images/towing.png",
};

const trustCards = [
	{
		title: "Honest Service",
		text: "Clear communication and straightforward estimates before repair work begins.",
	},
	{
		title: "Experienced Technicians",
		text: "Capable repair support for routine maintenance, diagnostics, and larger repairs.",
	},
	{
		title: "Convenient Location",
		text: "Easy to find on North State Road 7 in the heart of Margate.",
	},
	{
		title: "Dependable Repairs",
		text: "Service focused on getting everyday drivers safely back on the road.",
	},
];

const services = [
	{
		title: "Oil Changes",
		text: "Routine oil and filter service to help keep your vehicle running smoothly.",
		image: images.maintenance,
	},
	{
		title: "Brake Service",
		text: "Brake pads, rotors, inspections, and repairs focused on everyday safety.",
		image: images.brake,
	},
	{
		title: "Electrical Diagnostics",
		text: "Troubleshooting for batteries, starters, alternators, wiring, and warning lights.",
		image: images.electrical,
	},
	{
		title: "Engine Repair",
		text: "Diagnostics and repair for noises, leaks, performance issues, and warning signs.",
		image: images.engine,
	},
	{
		title: "Transmission Service",
		text: "Careful inspection and service for shifting concerns and drivability issues.",
		image: images.transmission,
	},
	{
		title: "A/C Repair",
		text: "Testing and repair to keep your vehicle comfortable in South Florida heat.",
		image: images.ac,
	},
	{
		title: "Towing & Roadside Assistance",
		text: "Helpful support when your vehicle cannot make it to the shop on its own.",
		image: images.towing,
	},
];

const process = [
	["1", "Call or Request Service", "Tell the shop what is happening and choose a convenient time."],
	["2", "Vehicle Inspection", "A technician checks the vehicle and identifies the repair path."],
	["3", "Clear Estimate", "You get a straightforward explanation before work moves forward."],
	["4", "Professional Repair", "The repair is completed with attention to safety and reliability."],
];

const reviews = [
	{
		name: "Local Customer",
		text: "The team was friendly, explained the repair clearly, and made the visit feel simple.",
	},
	{
		name: "Margate Driver",
		text: "Fair pricing and professional service. I appreciated that they took time to answer questions.",
	},
	{
		name: "Repeat Customer",
		text: "Fast help, clear communication, and a neighborhood-shop feel that makes it easy to come back.",
	},
];

const values = [
	{
		title: "Transparent",
		text: "Customers should understand what is being repaired and why it matters.",
	},
	{
		title: "Respectful",
		text: "The experience should feel friendly, practical, and low pressure.",
	},
	{
		title: "Reliable",
		text: "Repairs and maintenance are handled with everyday safety in mind.",
	},
];
---

<Layout>
	<header class="site-header" data-header>
		<a class="brand" href="#home" aria-label="Margate Auto Repair home">
			<img class="brand-logo" src={images.logo} alt="Margate Auto Repair logo" />
			<span>
				<strong>Margate Auto Repair</strong>
				<small>Neighborhood Auto Care</small>
			</span>
		</a>

		<nav class="main-nav" aria-label="Primary navigation">
			{navItems.map((item) => <a href={item.href}>{item.label}</a>)}
		</nav>

		<a class="nav-call" href={phoneHref} aria-label="Call Margate Auto Repair">
			<span>Call Now</span>
		</a>
	</header>

	<main id="home">
		<section class="hero">
			<div class="hero-bg" style={`background-image: url("${images.hero}")`} aria-hidden="true"></div>
			<div class="hero-overlay" aria-hidden="true"></div>
			<div class="hero-inner">
				<div class="hero-copy reveal">
					<p class="eyebrow">Trusted neighborhood repair in Margate</p>
					<h1>Honest Auto Repair for Everyday Drivers.</h1>
					<p>
						Friendly service, clear estimates, and dependable repairs from a local garage
						focused on helping Margate families get back on the road with confidence.
					</p>
					<div class="hero-actions">
						<a class="btn btn-primary" href={phoneHref}>
							<span>Call Now</span>
						</a>
						<a class="btn btn-secondary" href={appointmentHref}>
							<span>Schedule Service</span>
						</a>
					</div>
				</div>

				<div class="hero-card reveal">
					<span class="status-dot"></span>
					<div>
						<strong>Open 7 days a week</strong>
						<p>2099 North State Rd. 7, Margate, FL 33063</p>
					</div>
				</div>
			</div>
		</section>

		<section class="trust section-pad" aria-label="Trust highlights">
			<div class="section-heading reveal">
				<p class="eyebrow">Why drivers choose us</p>
				<h2>Practical auto care with the clarity people expect from a local shop.</h2>
			</div>
			<div class="trust-grid">
				{
					trustCards.map((card) => (
						<article class="trust-card reveal">
							<span class="card-accent" aria-hidden="true"></span>
							<h3>{card.title}</h3>
							<p>{card.text}</p>
						</article>
					))
				}
			</div>
		</section>

		<section class="services section-pad" id="services">
			<div class="section-heading centered reveal">
				<p class="eyebrow">Services</p>
				<h2>Complete repair and maintenance for family vehicles.</h2>
				<p>
					From oil changes to diagnostics, the shop is built for the service needs local
					drivers deal with every day.
				</p>
			</div>
			<div class="service-grid">
				{
					services.map((service) => (
						<article class="service-card reveal">
							<img src={service.image} alt={`${service.title} at Margate Auto Repair`} loading="lazy" />
							<div class="service-card-body">
								<h3>{service.title}</h3>
								<p>{service.text}</p>
								<a href="#contact">Request service</a>
							</div>
						</article>
					))
				}
			</div>
		</section>

		<section class="story section-pad" id="about">
			<div class="story-grid">
				<div class="story-image reveal">
					<img
						src={images.about}
						alt="Exterior lot at Margate Auto Repair"
						loading="lazy"
					/>
				</div>
				<div class="story-copy reveal">
					<p class="eyebrow">About the shop</p>
					<h2>A neighborhood repair garage built around fair, friendly service.</h2>
					<p>
						Margate Auto Repair is committed to providing automotive repair at fair prices
						while delivering friendly, professional customer service. The experience is
						designed to be clear, respectful, and dependable from the first call to pickup.
					</p>
					<div class="value-grid">
						{
							values.map((value) => (
								<article class="value-card">
									<span class="value-mark" aria-hidden="true"></span>
									<h3>{value.title}</h3>
									<p>{value.text}</p>
								</article>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<section class="why section-pad">
			<div class="why-grid">
				<div class="why-copy reveal">
					<p class="eyebrow">Why choose us</p>
					<h2>Real technicians, real repairs, and a shop you can recognize when you arrive.</h2>
					<p>
						The site now puts the actual business environment front and center, so visitors
						can see the kind of local repair garage they are calling before they schedule.
					</p>
					<div class="why-points">
						<div>
							<span>General repair and diagnostics</span>
						</div>
						<div>
							<span>Tire and maintenance support</span>
						</div>
					</div>
				</div>
				<div class="why-photos reveal">
					<img
						src={images.generalRepair}
						alt="General repair work at Margate Auto Repair"
						loading="lazy"
					/>
					<img
						src={images.tire}
						alt="Technician replacing a tire at Margate Auto Repair"
						loading="lazy"
					/>
				</div>
			</div>
		</section>

		<section class="process section-pad">
			<div class="section-heading centered reveal">
				<p class="eyebrow">What to expect</p>
				<h2>A straightforward repair process.</h2>
			</div>
			<ol class="process-list">
				{
					process.map(([number, title, text]) => (
						<li class="process-step reveal">
							<span>{number}</span>
							<h3>{title}</h3>
							<p>{text}</p>
						</li>
					))
				}
			</ol>
		</section>

		<section class="reviews section-pad" id="reviews">
			<div class="reviews-grid">
				<div class="section-heading reveal">
					<p class="eyebrow">Customer reviews</p>
					<h2>Placeholder reviews with the tone this site should earn.</h2>
					<p>
						These sample reviews are written to highlight honesty, fair pricing, and fast,
						professional help. Replace them with verified customer reviews before launch.
					</p>
				</div>
				<div class="review-list">
					{
						reviews.map((review) => (
							<article class="review-card reveal">
								<div class="rating" aria-label="5 out of 5 stars">5.0</div>
								<p>"{review.text}"</p>
								<strong>{review.name}</strong>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="contact section-pad" id="contact">
			<div class="contact-grid">
				<div class="contact-panel reveal">
					<p class="eyebrow">Visit or call</p>
					<h2>Schedule service with Margate Auto Repair.</h2>
					<p>
						Conveniently located on North State Road 7, with hours throughout the week for
						routine maintenance, diagnostics, and repair needs.
					</p>
					<div class="contact-actions">
						<a class="btn btn-primary" href={phoneHref}>
							<span>Call Now</span>
						</a>
						<a class="btn btn-dark" href="mailto:appointments@margateautorepair.example">
							<span>Schedule Service</span>
						</a>
					</div>
				</div>

				<div class="details-card reveal">
					<div>
						<h3>Address</h3>
						<p>2099 North State Rd. 7<br />Margate, FL 33063</p>
					</div>
					<div>
						<h3>Business Hours</h3>
						<p><strong>Monday-Friday</strong><br />7:00 AM - 6:00 PM</p>
						<p><strong>Saturday</strong><br />8:00 AM - 5:00 PM</p>
						<p><strong>Sunday</strong><br />9:00 AM - 4:00 PM</p>
					</div>
				</div>

				<div class="map-card reveal">
					<iframe
						title="Map to Margate Auto Repair"
						src="https://www.google.com/maps?q=2099%20North%20State%20Rd.%207%2C%20Margate%2C%20FL%2033063&output=embed"
						loading="lazy"
						referrerpolicy="no-referrer-when-downgrade"></iframe>
				</div>
			</div>
		</section>
	</main>

	<footer class="site-footer">
		<img src={images.logo} alt="Margate Auto Repair logo" />
		<span>Neighborhood auto repair in Margate, FL.</span>
	</footer>
</Layout>

<style>
	:global(body) {
		background: #f6f8fb;
		color: #17202a;
	}

	.site-header {
		align-items: center;
		backdrop-filter: blur(18px);
		background: rgba(255, 255, 255, 0.94);
		border-bottom: 1px solid rgba(20, 31, 45, 0.08);
		display: flex;
		gap: 1rem;
		justify-content: space-between;
		left: 0;
		min-height: 76px;
		padding: 0.85rem clamp(1rem, 4vw, 3rem);
		position: sticky;
		right: 0;
		top: 0;
		transition: box-shadow 180ms ease, background 180ms ease;
		z-index: 50;
	}

	.site-header.is-scrolled {
		background: rgba(255, 255, 255, 0.98);
		box-shadow: 0 18px 44px rgba(11, 30, 51, 0.1);
	}

	.brand,
	.nav-call,
	.btn,
	.main-nav a,
	.service-card a {
		text-decoration: none;
	}

	.brand {
		align-items: center;
		display: inline-flex;
		gap: 0.7rem;
	}

	.brand-logo {
		background: #fff;
		border-radius: 8px;
		box-shadow: 0 8px 20px rgba(13, 32, 52, 0.08);
		height: 46px;
		object-fit: contain;
		padding: 0.3rem;
		width: 58px;
	}

	.brand strong,
	.brand small {
		display: block;
		line-height: 1.1;
	}

	.brand strong {
		color: #0b1f35;
		font-size: 0.96rem;
	}

	.brand small {
		color: #657282;
		font-size: 0.72rem;
		margin-top: 0.22rem;
	}

	.main-nav {
		align-items: center;
		display: flex;
		gap: clamp(0.8rem, 2vw, 1.7rem);
	}

	.main-nav a {
		color: #334152;
		font-size: 0.9rem;
		font-weight: 800;
		position: relative;
		transition: color 180ms ease;
	}

	.main-nav a::after {
		background: #ef9d1f;
		border-radius: 999px;
		bottom: -0.4rem;
		content: "";
		height: 2px;
		left: 0;
		position: absolute;
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 180ms ease;
		width: 100%;
	}

	.main-nav a:hover {
		color: #0b1f35;
	}

	.main-nav a:hover::after {
		transform: scaleX(1);
	}

	.nav-call,
	.btn {
		align-items: center;
		border-radius: 8px;
		display: inline-flex;
		font-weight: 900;
		gap: 0.55rem;
		justify-content: center;
		line-height: 1;
		transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
		white-space: nowrap;
	}

	.nav-call {
		background: #ef9d1f;
		color: #111820;
		min-height: 44px;
		padding: 0 1rem;
	}

	.btn {
		min-height: 56px;
		padding: 0 1.25rem;
	}

	.nav-call:hover,
	.btn:hover {
		transform: translateY(-2px);
	}

	.btn-primary {
		background: #ef9d1f;
		box-shadow: 0 18px 42px rgba(239, 157, 31, 0.28);
		color: #111820;
	}

	.btn-secondary {
		background: #fff;
		color: #0b1f35;
	}

	.btn-dark {
		background: #0b1f35;
		color: #fff;
	}

	.section-pad {
		padding: clamp(4.75rem, 9vw, 7.8rem) clamp(1rem, 4vw, 3rem);
	}

	.hero {
		align-items: center;
		background: #0b1f35;
		color: #fff;
		display: grid;
		min-height: calc(100vh - 76px);
		overflow: hidden;
		padding: clamp(5rem, 9vw, 8rem) clamp(1rem, 4vw, 3rem);
		position: relative;
	}

	.hero-bg,
	.hero-overlay {
		inset: 0;
		position: absolute;
	}

	.hero-bg {
		background-position: center 48%;
		background-size: cover;
		transform: scale(1.02);
	}

	.hero-overlay {
		background:
			linear-gradient(90deg, rgba(7, 24, 39, 0.9) 0%, rgba(7, 24, 39, 0.72) 44%, rgba(7, 24, 39, 0.32) 100%),
			linear-gradient(0deg, rgba(7, 24, 39, 0.68), transparent 46%);
	}

	.hero-inner,
	.trust-grid,
	.service-grid,
	.story-grid,
	.process-list,
	.reviews-grid,
	.contact-grid {
		margin: 0 auto;
		max-width: 1180px;
		position: relative;
		width: 100%;
	}

	.hero-inner {
		align-items: end;
		display: grid;
		gap: clamp(2rem, 6vw, 5rem);
		grid-template-columns: minmax(0, 0.95fr) minmax(280px, 0.45fr);
	}

	.hero-copy {
		max-width: 760px;
	}

	.eyebrow {
		color: #1677c7;
		font-size: 0.78rem;
		font-weight: 900;
		letter-spacing: 0;
		margin: 0 0 0.85rem;
		text-transform: uppercase;
	}

	.hero .eyebrow {
		color: #ffbd52;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1 {
		color: #fff;
		font-size: clamp(2.85rem, 7vw, 6.1rem);
		line-height: 0.98;
		margin-bottom: 1.35rem;
		max-width: 850px;
	}

	h2 {
		color: #0b1f35;
		font-size: clamp(2rem, 4vw, 3.65rem);
		line-height: 1.03;
		margin-bottom: 1rem;
	}

	h3 {
		color: #0f2338;
		font-size: 1.06rem;
		line-height: 1.24;
		margin-bottom: 0.55rem;
	}

	p {
		color: #5c6978;
		line-height: 1.72;
	}

	.hero-copy p:not(.eyebrow) {
		color: #e1e9f0;
		font-size: clamp(1.08rem, 2vw, 1.32rem);
		max-width: 680px;
	}

	.hero-actions,
	.contact-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		margin-top: 2rem;
	}

	.hero-card {
		align-items: flex-start;
		backdrop-filter: blur(16px);
		background: rgba(255, 255, 255, 0.94);
		border: 1px solid rgba(255, 255, 255, 0.45);
		border-radius: 8px;
		box-shadow: 0 24px 70px rgba(3, 12, 24, 0.26);
		color: #0b1f35;
		display: flex;
		gap: 0.85rem;
		padding: 1.1rem;
	}

	.hero::after {
		background: #ef9d1f;
		bottom: 0;
		content: "";
		height: 5px;
		left: 0;
		position: absolute;
		right: 0;
	}

	.hero-card p {
		margin: 0.2rem 0 0;
	}

	.status-dot {
		background: #24b47e;
		border-radius: 999px;
		box-shadow: 0 0 0 6px rgba(36, 180, 126, 0.14);
		flex: 0 0 auto;
		height: 0.7rem;
		margin-top: 0.35rem;
		width: 0.7rem;
	}

	.section-heading {
		margin: 0 auto 2.2rem;
		max-width: 780px;
	}

	.section-heading.centered {
		text-align: center;
	}

	.section-heading.centered p {
		margin-left: auto;
		margin-right: auto;
		max-width: 680px;
	}

	.trust {
		background: #fff;
	}

	.trust-grid {
		display: grid;
		gap: 1rem;
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.trust-card,
	.service-card,
	.value-card,
	.process-step,
	.review-card,
	.contact-panel,
	.details-card,
	.map-card {
		background: #fff;
		border: 1px solid rgba(20, 31, 45, 0.09);
		border-radius: 8px;
		box-shadow: 0 18px 44px rgba(13, 32, 52, 0.08);
	}

	.trust-card,
	.service-card,
	.process-step,
	.review-card {
		transition: border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
	}

	.trust-card:hover,
	.service-card:hover,
	.process-step:hover,
	.review-card:hover {
		border-color: rgba(22, 119, 199, 0.25);
		box-shadow: 0 24px 54px rgba(13, 32, 52, 0.12);
		transform: translateY(-4px);
	}

	.trust-card {
		min-height: 220px;
		overflow: hidden;
		padding: 1.35rem;
		position: relative;
	}

	.card-accent {
		background: #ef9d1f;
		border-radius: 999px;
		display: block;
		height: 4px;
		margin-bottom: 1.2rem;
		width: 58px;
	}

	.services {
		background: #f6f8fb;
	}

	.service-grid {
		display: grid;
		gap: 1rem;
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.service-card {
		display: flex;
		flex-direction: column;
		min-height: 100%;
		overflow: hidden;
		padding: 0;
	}

	.service-card img {
		display: block;
		height: 210px;
		object-fit: cover;
		transition: transform 260ms ease;
		width: 100%;
	}

	.service-card:hover img {
		transform: scale(1.04);
	}

	.service-card-body {
		display: flex;
		flex: 1;
		flex-direction: column;
		padding: 1.2rem;
	}

	.service-card p {
		font-size: 0.94rem;
		margin-bottom: 1rem;
	}

	.service-card a {
		color: #1677c7;
		font-size: 0.9rem;
		font-weight: 900;
		margin-top: auto;
	}

	.story {
		background: #fff;
	}

	.story-grid {
		align-items: center;
		display: grid;
		gap: clamp(1.6rem, 5vw, 4rem);
		grid-template-columns: 0.9fr 1.1fr;
	}

	.story-image {
		border-radius: 8px;
		box-shadow: 0 24px 58px rgba(13, 32, 52, 0.13);
		overflow: hidden;
	}

	.story-image img {
		aspect-ratio: 4 / 5;
		height: 100%;
		object-fit: cover;
		width: 100%;
	}

	.why {
		background: #f6f8fb;
	}

	.why-grid {
		align-items: center;
		display: grid;
		gap: clamp(1.6rem, 5vw, 4rem);
		margin: 0 auto;
		max-width: 1180px;
		grid-template-columns: 0.85fr 1.15fr;
	}

	.why-copy {
		max-width: 560px;
	}

	.why-points {
		display: grid;
		gap: 0.8rem;
		margin-top: 1.6rem;
	}

