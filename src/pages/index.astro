---
import Layout from "../layouts/Layout.astro";

const phoneHref = "tel:+19545550197";
const appointmentHref = "#contact";

const navItems = [
	{ label: "Home", href: "#home" },
	{ label: "Services", href: "#services" },
	{ label: "About", href: "#about" },
	{ label: "Reviews", href: "#reviews" },
	{ label: "Contact", href: "#contact" },
];

const images = {
	logo: "/images/logo.png",
	hero: "/images/busy outside lot.png",
	about: "/images/empty lot.png",
	generalRepair: "/images/general repair.png",
	tire: "/images/replacing a tire.png",
	maintenance: "/images/maintenance.png",
	brake: "/images/brake repair.png",
	electrical: "/images/electrical.png",
	engine: "/images/engine.png",
	transmission: "/images/transmission.png",
	ac: "/images/ac repair.png",
	towing: "/images/towing.png",
};

const trustCards = [
	{
		title: "Honest Service",
		text: "Clear communication and straightforward estimates before repair work begins.",
	},
	{
		title: "Experienced Technicians",
		text: "Capable repair support for routine maintenance, diagnostics, and larger repairs.",
	},
	{
		title: "Convenient Location",
		text: "Easy to find on North State Road 7 in the heart of Margate.",
	},
	{
		title: "Dependable Repairs",
		text: "Service focused on getting everyday drivers safely back on the road.",
	},
];

const services = [
	{
		title: "Oil Changes",
		text: "Routine oil and filter service to help keep your vehicle running smoothly.",
		image: images.maintenance,
	},
	{
		title: "Brake Service",
		text: "Brake pads, rotors, inspections, and repairs focused on everyday safety.",
		image: images.brake,
	},
	{
		title: "Electrical Diagnostics",
		text: "Troubleshooting for batteries, starters, alternators, wiring, and warning lights.",
		image: images.electrical,
	},
	{
		title: "Engine Repair",
		text: "Diagnostics and repair for noises, leaks, performance issues, and warning signs.",
		image: images.engine,
	},
	{
		title: "Transmission Service",
		text: "Careful inspection and service for shifting concerns and drivability issues.",
		image: images.transmission,
	},
	{
		title: "A/C Repair",
		text: "Testing and repair to keep your vehicle comfortable in South Florida heat.",
		image: images.ac,
	},
	{
		title: "Towing & Roadside Assistance",
		text: "Helpful support when your vehicle cannot make it to the shop on its own.",
		image: images.towing,
	},
];

const process = [
	["1", "Call or Request Service", "Tell the shop what is happening and choose a convenient time."],
	["2", "Vehicle Inspection", "A technician checks the vehicle and identifies the repair path."],
	["3", "Clear Estimate", "You get a straightforward explanation before work moves forward."],
	["4", "Professional Repair", "The repair is completed with attention to safety and reliability."],
];

const reviews = [
	{
		name: "Randy Bodziak",
		rating: "5.0",
		text: "No games, no hidden anything&mdash;just straight-up good work.",
	},
	{
		name: "Alex Deltoro",
		rating: "5.0",
		text: "Fast and excellent service. Customer service is amazing!",
	},
	{
		name: "Maria Isaias",
		rating: "5.0",
		text: "The mechanic who did the job knew exactly what to do and was great.",
	},
];

const values = [
	{
		title: "Transparent",
		text: "Customers should understand what is being repaired and why it matters.",
	},
	{
		title: "Respectful",
		text: "The experience should feel friendly, practical, and low pressure.",
	},
	{
		title: "Reliable",
		text: "Repairs and maintenance are handled with everyday safety in mind.",
	},
];
---

<Layout>
	<header class="site-header" data-header>
		<a class="brand" href="#home" aria-label="Margate Auto Repair home">
			<img class="brand-logo" src={images.logo} alt="Margate Auto Repair logo" />
			<span>
				<strong>Margate Auto Repair</strong>
				<small>Neighborhood Auto Care</small>
			</span>
		</a>

		<nav class="main-nav" aria-label="Primary navigation">
			{navItems.map((item) => <a href={item.href}>{item.label}</a>)}
		</nav>

		<a class="nav-call" href={phoneHref} aria-label="Call Margate Auto Repair">
			<span>Call Now</span>
		</a>
	</header>

	<main id="home">
		<section class="hero">
			<div class="hero-bg" style={`background-image: url("${images.hero}")`} aria-hidden="true"></div>
			<div class="hero-overlay" aria-hidden="true"></div>
			<div class="hero-inner">
				<div class="hero-copy reveal">
					<p class="eyebrow">Trusted neighborhood repair in Margate</p>
					<h1>Honest Auto Repair for Everyday Drivers.</h1>
					<p>
						Friendly service, clear estimates, and dependable repairs from a local garage
						focused on helping Margate families get back on the road with confidence.
					</p>
					<div class="hero-actions">
						<a class="btn btn-primary" href={phoneHref}>
							<span>Call Now</span>
						</a>
						<a class="btn btn-secondary" href={appointmentHref}>
							<span>Schedule Service</span>
						</a>
					</div>
				</div>

				<div class="hero-card reveal">
					<span class="status-dot"></span>
					<div>
						<strong>Open 7 days a week</strong>
						<p>2099 North State Rd. 7, Margate, FL 33063</p>
					</div>
				</div>
			</div>
		</section>

		<section class="trust section-pad" aria-label="Trust highlights">
			<div class="section-heading reveal">
				<p class="eyebrow">Why drivers choose us</p>
				<h2>Practical auto care with the clarity people expect from a local shop.</h2>
			</div>
			<div class="trust-grid">
				{
					trustCards.map((card) => (
						<article class="trust-card reveal">
							<span class="card-accent" aria-hidden="true"></span>
							<h3>{card.title}</h3>
							<p>{card.text}</p>
						</article>
					))
				}
			</div>
		</section>

		<section class="services section-pad" id="services">
			<div class="section-heading centered reveal">
				<p class="eyebrow">Services</p>
				<h2>Complete repair and maintenance for family vehicles.</h2>
				<p>
					From oil changes to diagnostics, the shop is built for the service needs local
					drivers deal with every day.
				</p>
			</div>
			<div class="service-grid">
				{
					services.map((service) => (
						<article class="service-card reveal">
							<img src={service.image} alt={`${service.title} at Margate Auto Repair`} loading="lazy" />
							<div class="service-card-body">
								<h3>{service.title}</h3>
								<p>{service.text}</p>
								<a href="#contact">Request service</a>
							</div>
						</article>
					))
				}
			</div>
		</section>

		<section class="story section-pad" id="about">
			<div class="story-grid">
				<div class="story-image reveal">
					<img
						src={images.about}
						alt="Exterior lot at Margate Auto Repair"
						loading="lazy"
					/>
				</div>
				<div class="story-copy reveal">
					<p class="eyebrow">About the shop</p>
					<h2>A neighborhood repair garage built around fair, friendly service.</h2>
					<p>
						Margate Auto Repair is committed to providing automotive repair at fair prices
						while delivering friendly, professional customer service. The experience is
						designed to be clear, respectful, and dependable from the first call to pickup.
					</p>
					<div class="value-grid">
						{
							values.map((value) => (
								<article class="value-card">
									<span class="value-mark" aria-hidden="true"></span>
									<h3>{value.title}</h3>
									<p>{value.text}</p>
								</article>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<section class="why section-pad">
			<div class="why-grid">
				<div class="why-copy reveal">
					<p class="eyebrow">Why choose us</p>
					<h2>Real technicians, real repairs, and a shop you can recognize when you arrive.</h2>
					<p>
						The site now puts the actual business environment front and center, so visitors
						can see the kind of local repair garage they are calling before they schedule.
					</p>
					<div class="why-points">
						<div>
							<span>General repair and diagnostics</span>
						</div>
						<div>
							<span>Tire and maintenance support</span>
						</div>
					</div>
				</div>
				<div class="why-photos reveal">
					<img
						src={images.generalRepair}
						alt="General repair work at Margate Auto Repair"
						loading="lazy"
					/>
					<img
						src={images.tire}
						alt="Technician replacing a tire at Margate Auto Repair"
						loading="lazy"
					/>
				</div>
			</div>
		</section>

		<section class="process section-pad">
			<div class="section-heading centered reveal">
				<p class="eyebrow">What to expect</p>
				<h2>A straightforward repair process.</h2>
			</div>
			<ol class="process-list">
				{
					process.map(([number, title, text]) => (
						<li class="process-step reveal">
							<span>{number}</span>
							<h3>{title}</h3>
							<p>{text}</p>
						</li>
					))
				}
			</ol>
		</section>

		<section class="reviews section-pad" id="reviews">
			<div class="reviews-grid">
				<div class="section-heading reveal">
					<p class="eyebrow">Customer reviews</p>
					<h2>Real feedback from drivers who trust the shop.</h2>
					<p>
						Straightforward repairs, helpful service, and the kind of local experience that
						keeps Margate drivers coming back.
					</p>
				</div>
				<div class="review-list">
					{
						reviews.map((review) => (
							<article class="review-card reveal">
								<div class="rating-row" aria-label={`${review.rating} out of 5 stars`}>
									<span class="rating">{review.rating}</span>
									<span class="stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
								</div>
								<p set:html={`&ldquo;${review.text}&rdquo;`} />
								<div class="review-author">
									<strong>{review.name}</strong>
									<span>Verified Google Review</span>
								</div>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="contact section-pad" id="contact">
			<div class="contact-grid">
				<div class="contact-panel reveal">
					<p class="eyebrow">Visit or call</p>
					<h2>Schedule service with Margate Auto Repair.</h2>
					<p>
						Conveniently located on North State Road 7, with hours throughout the week for
						routine maintenance, diagnostics, and repair needs.
					</p>
					<div class="contact-actions">
						<a class="btn btn-primary" href={phoneHref}>
							<span>Call Now</span>
						</a>
						<a class="btn btn-dark" href="mailto:appointments@margateautorepair.example">
							<span>Schedule Service</span>
						</a>
					</div>
				</div>

				<div class="details-card reveal">
					<div>
						<h3>Address</h3>
						<p>2099 North State Rd. 7<br />Margate, FL 33063</p>
					</div>
					<div>
						<h3>Business Hours</h3>
						<p><strong>Monday-Friday</strong><br />7:00 AM - 6:00 PM</p>
						<p><strong>Saturday</strong><br />8:00 AM - 5:00 PM</p>
						<p><strong>Sunday</strong><br />9:00 AM - 4:00 PM</p>
					</div>
				</div>

				<div class="map-card reveal">
					<iframe
						title="Map to Margate Auto Repair"
						src="https://www.google.com/maps?q=2099%20North%20State%20Rd.%207%2C%20Margate%2C%20FL%2033063&output=embed"
						loading="lazy"
						referrerpolicy="no-referrer-when-downgrade"></iframe>
				</div>
			</div>
		</section>
	</main>

	<footer class="site-footer">
		<img src={images.logo} alt="Margate Auto Repair logo" />
		<span>Neighborhood auto repair in Margate, FL.</span>
	</footer>
</Layout>

<style>
	:global(:root) {
		--navy: #071827;
		--navy-2: #0b1f35;
		--blue: #1677c7;
		--blue-soft: #eaf5ff;
		--gold: #ef9d1f;
		--ink: #17202a;
		--muted: #5c6978;
		--line: rgba(20, 31, 45, 0.1);
		--surface: #ffffff;
		--wash: #f6f8fb;
		--shadow-sm: 0 12px 28px rgba(13, 32, 52, 0.08);
		--shadow-md: 0 22px 54px rgba(13, 32, 52, 0.12);
		--shadow-lg: 0 32px 84px rgba(3, 12, 24, 0.28);
		--radius: 8px;
	}

	:global(body) {
		background: var(--wash);
		color: var(--ink);
	}

	.site-header {
		align-items: center;
		backdrop-filter: blur(18px);
		background: rgba(255, 255, 255, 0.94);
		border-bottom: 1px solid rgba(20, 31, 45, 0.07);
		display: flex;
		gap: 1rem;
		justify-content: space-between;
		left: 0;
		min-height: 76px;
		padding: 0.8rem clamp(1rem, 4vw, 3rem);
		position: sticky;
		right: 0;
		top: 0;
		transition: box-shadow 220ms ease, background 220ms ease, border-color 220ms ease;
		z-index: 50;
	}

	.site-header.is-scrolled {
		background: rgba(255, 255, 255, 0.98);
		border-color: transparent;
		box-shadow: 0 18px 44px rgba(11, 30, 51, 0.1);
	}

	.brand,
	.nav-call,
	.btn,
	.main-nav a,
	.service-card a {
		text-decoration: none;
	}

	.brand {
		align-items: center;
		display: inline-flex;
		gap: 0.7rem;
		transition: transform 180ms ease;
	}

	.brand:hover {
		transform: translateY(-1px);
	}

	.brand-logo {
		background: #fff;
		border: 1px solid rgba(20, 31, 45, 0.08);
		border-radius: var(--radius);
		box-shadow: var(--shadow-sm);
		height: 48px;
		object-fit: contain;
		padding: 0.32rem;
		width: 62px;
	}

	.brand strong,
	.brand small {
		display: block;
		line-height: 1.1;
	}

	.brand strong {
		color: var(--navy-2);
		font-size: 1rem;
		font-weight: 900;
	}

	.brand small {
		color: #657282;
		font-size: 0.72rem;
		font-weight: 750;
		margin-top: 0.22rem;
	}

	.main-nav {
		align-items: center;
		display: flex;
		gap: clamp(0.8rem, 2vw, 1.7rem);
	}

	.main-nav a {
		color: #334152;
		font-size: 0.9rem;
		font-weight: 850;
		position: relative;
		transition: color 180ms ease, transform 180ms ease;
	}

	.main-nav a::after {
		background: var(--gold);
		border-radius: 999px;
		bottom: -0.4rem;
		content: "";
		height: 2px;
		left: 0;
		position: absolute;
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 180ms ease;
		width: 100%;
	}

	.main-nav a:hover {
		color: var(--navy-2);
		transform: translateY(-1px);
	}

	.main-nav a:hover::after {
		transform: scaleX(1);
	}

	.nav-call,
	.btn {
		align-items: center;
		border-radius: var(--radius);
		display: inline-flex;
		font-weight: 900;
		gap: 0.55rem;
		justify-content: center;
		line-height: 1;
		position: relative;
		transition: transform 200ms ease, box-shadow 200ms ease, background 200ms ease, color 200ms ease;
		white-space: nowrap;
	}

	.nav-call {
		background: var(--gold);
		color: #111820;
		min-height: 44px;
		padding: 0 1.05rem;
		box-shadow: 0 12px 26px rgba(239, 157, 31, 0.22);
	}

	.btn {
		min-height: 58px;
		min-width: 158px;
		padding: 0 1.35rem;
	}

	.nav-call:hover,
	.btn:hover {
		transform: translateY(-2px);
	}

	.btn:focus-visible,
	.nav-call:focus-visible,
	.main-nav a:focus-visible {
		outline: 3px solid rgba(22, 119, 199, 0.35);
		outline-offset: 4px;
	}

	.btn-primary {
		background: var(--gold);
		box-shadow: 0 18px 42px rgba(239, 157, 31, 0.28);
		color: #111820;
	}

	.btn-primary:hover,
	.nav-call:hover {
		background: #ffb33c;
		box-shadow: 0 20px 46px rgba(239, 157, 31, 0.34);
	}

	.btn-secondary {
		background: #fff;
		box-shadow: 0 18px 42px rgba(3, 12, 24, 0.16);
		color: var(--navy-2);
	}

	.btn-secondary:hover {
		background: #f4f8fb;
	}

	.btn-dark {
		background: var(--navy-2);
		color: #fff;
	}

	.btn-dark:hover {
		background: var(--navy);
		box-shadow: 0 18px 42px rgba(11, 31, 53, 0.22);
	}

	.section-pad {
		padding: clamp(5.5rem, 9vw, 8.6rem) clamp(1rem, 4vw, 3rem);
	}

	.hero {
		align-items: center;
		background: var(--navy-2);
		color: #fff;
		display: grid;
		min-height: calc(100vh - 76px);
		overflow: hidden;
		padding: clamp(5.7rem, 9vw, 8.6rem) clamp(1rem, 4vw, 3rem);
		position: relative;
	}

	.hero-bg,
	.hero-overlay {
		inset: 0;
		position: absolute;
	}

	.hero-bg {
		background-position: center 48%;
		background-size: cover;
		filter: saturate(0.96) contrast(1.03);
		transform: scale(1.015);
	}

	.hero-overlay {
		background:
			linear-gradient(90deg, rgba(7, 24, 39, 0.91) 0%, rgba(7, 24, 39, 0.74) 45%, rgba(7, 24, 39, 0.3) 100%),
			linear-gradient(0deg, rgba(7, 24, 39, 0.66), transparent 48%);
	}

	.hero-inner,
	.trust-grid,
	.service-grid,
	.story-grid,
	.process-list,
	.reviews-grid,
	.contact-grid {
		margin: 0 auto;
		max-width: 1180px;
		position: relative;
		width: 100%;
	}

	.hero-inner {
		align-items: end;
		display: grid;
		gap: clamp(2rem, 6vw, 5.5rem);
		grid-template-columns: minmax(0, 0.95fr) minmax(280px, 0.45fr);
	}

	.hero-copy {
		max-width: 760px;
	}

	.eyebrow {
		color: var(--blue);
		font-size: 0.76rem;
		font-weight: 900;
		letter-spacing: 0;
		margin: 0 0 0.95rem;
		text-transform: uppercase;
	}

	.hero .eyebrow {
		color: #ffbd52;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1 {
		color: #fff;
		font-size: clamp(3rem, 7vw, 6.35rem);
		font-weight: 950;
		line-height: 0.96;
		margin-bottom: 1.45rem;
		max-width: 850px;
		text-wrap: balance;
	}

	h2 {
		color: var(--navy-2);
		font-size: clamp(2.05rem, 4vw, 3.75rem);
		font-weight: 930;
		line-height: 1.02;
		margin-bottom: 1.05rem;
		text-wrap: balance;
	}

	h3 {
		color: #0f2338;
		font-size: 1.08rem;
		font-weight: 900;
		line-height: 1.22;
		margin-bottom: 0.58rem;
	}

	p {
		color: var(--muted);
		line-height: 1.72;
	}

	.hero-copy p:not(.eyebrow) {
		color: #e1e9f0;
		font-size: clamp(1.08rem, 2vw, 1.34rem);
		line-height: 1.68;
		max-width: 680px;
	}

	.hero-actions,
	.contact-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
		margin-top: 2.2rem;
	}

	.hero-card {
		align-items: flex-start;
		backdrop-filter: blur(16px);
		background: rgba(255, 255, 255, 0.94);
		border: 1px solid rgba(255, 255, 255, 0.45);
		border-radius: var(--radius);
		box-shadow: var(--shadow-lg);
		color: var(--navy-2);
		display: flex;
		gap: 0.85rem;
		padding: 1.18rem;
	}

	.hero::after {
		background: var(--gold);
		bottom: 0;
		content: "";
		height: 5px;
		left: 0;
		position: absolute;
		right: 0;
	}

	.hero-card p {
		margin: 0.2rem 0 0;
	}

	.status-dot {
		background: #24b47e;
		border-radius: 999px;
		box-shadow: 0 0 0 6px rgba(36, 180, 126, 0.14);
		flex: 0 0 auto;
		height: 0.7rem;
		margin-top: 0.35rem;
		width: 0.7rem;
	}

	.section-heading {
		margin: 0 auto clamp(2.2rem, 4vw, 3.1rem);
		max-width: 820px;
	}

	.section-heading.centered {
		text-align: center;
	}

	.section-heading.centered p {
		margin-left: auto;
		margin-right: auto;
		max-width: 700px;
	}

	.trust {
		background: #fff;
	}

	.trust-grid {
		display: grid;
		gap: 1.05rem;
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.trust-card,
	.service-card,
	.value-card,
	.process-step,
	.review-card,
	.contact-panel,
	.details-card,
	.map-card {
		background: #fff;
		border: 1px solid rgba(20, 31, 45, 0.08);
		border-radius: var(--radius);
		box-shadow: var(--shadow-sm);
	}

	.trust-card,
	.service-card,
	.process-step,
	.review-card {
		transition: border-color 220ms ease, box-shadow 220ms ease, transform 220ms ease;
	}

	.trust-card:hover,
	.service-card:hover,
	.process-step:hover,
	.review-card:hover {
		border-color: rgba(22, 119, 199, 0.25);
		box-shadow: var(--shadow-md);
		transform: translateY(-5px);
	}

	.trust-card {
		min-height: 230px;
		overflow: hidden;
